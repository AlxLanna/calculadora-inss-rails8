<%# app/views/proponentes/dashboard.html.erb %>

<h1>Dashboard de Proponentes por Faixa Salarial</h1>

<div class="row">
  <div class="col-md-8">
    <h3>Distribuição Salarial (Gráfico)</h3>
    <div style="height: 400px; width: 100%;">
      <%= pie_chart @proponentes_por_faixa_ordenada, title: "Proponentes por Faixa Salarial", legend: "bottom" %>
      <%# Outras opções: bar_chart, column_chart %>
    </div>
  </div>
  <div class="col-md-4">
    <h3>Contagem por Faixa (Listagem)</h3>
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>Faixa Salarial</th>
          <th>Total de Proponentes</th>
        </tr>
      </thead>
      <tbody>
        <% @proponentes_por_faixa_ordenada.each do |faixa, contagem| %>
          <tr>
            <td><%= faixa %></td>
            <td><%= contagem %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-4">
  <%= link_to "Voltar para Listagem", proponentes_path, class: "btn btn-secondary" %>
</div>