<%# app/views/proponentes/index.html.erb %>

<h1>Lista de Proponentes</h1>

<div class="mb-3">
  <%= link_to "Novo Proponente", new_proponente_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Nome</th>
      <th>Salário</th>
      <th>Desconto INSS</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% @proponentes.each do |proponente| %>
      <tr>
        <td><%= proponente.nome %></td>
        <td>R$ <%= '%.2f' % proponente.salario %></td>
        <td>R$ <%= '%.2f' % proponente.desconto_inss %></td>
        <td>
          <%= link_to "Ver", proponente_path(proponente), class: "btn btn-info btn-sm" %>
          <%= link_to "Editar", edit_proponente_path(proponente), class: "btn btn-warning btn-sm" %>
          <%# o botão Excluir só aparece para admins %>
          <% if user_signed_in? && current_user.admin? %>
            <%= link_to "Excluir", proponente_path(proponente),
                        data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir #{proponente.nome}?" },
                        class: "btn btn-danger btn-sm" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%# Renderiza os links de paginação %>
<div class="d-flex justify-content-center">
  <%= paginate @proponentes %>
</div>